// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id @default(uuid())
  username      String   @unique
  password      String
  created_at    DateTime @default(now())
  refresh_token String?

  websites     UserWebsite[]
  websiteTicks WebsiteTick[]
  outBoxes     OutBox[]
}

model Website {
  id           String        @id @default(uuid())
  url          String        @unique
  created_at   DateTime      @default(now())
  user_website UserWebsite[]
  websiteTicks WebsiteTick[]
  outBoxes     OutBox[]
}

model UserWebsite {
  user_id          String
  website_id       String
  interval_seconds Int       @default(30)
  time_added       DateTime
  next_tick        DateTime
  last_tick        DateTime?
  is_active        Boolean   @default(true)

  user         User          @relation(fields: [user_id], references: [id])
  website      Website       @relation(fields: [website_id], references: [id])
  websiteTicks WebsiteTick[]

  @@id([user_id, website_id])
}

model WebsiteTick {
  id           String        @id
  website_id   String
  user_id      String
  latency_ms   Int
  status       WebsiteStatus
  timestamp    DateTime      @default(now())
  website      Website       @relation(fields: [website_id], references: [id])
  user         User          @relation(fields: [user_id], references: [id])
  user_website UserWebsite   @relation(fields: [user_id, website_id], references: [user_id, website_id], onDelete: Cascade)

  @@unique([id, timestamp])
  @@index([user_id, website_id, timestamp])
}

model OutBox {
  id          String     @id @default(uuid())
  user_id     String
  website_id  String
  task        OutBoxTask
  task_status TaskStatus @default(UnProcessed)
  created_at  DateTime   @default(now())
  updated_at  DateTime   @default(now())
  user        User       @relation(fields: [user_id], references: [id])
  website     Website    @relation(fields: [website_id], references: [id])

  @@index([task_status, task, updated_at])
}

enum TaskStatus {
  UnProcessed
  Processed
  Processing
}

enum OutBoxTask {
  Add
  Update
  Delete
}

enum WebsiteStatus {
  Up
  Down
  Unknown
}
